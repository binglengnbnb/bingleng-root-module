#
# 冰冷 (BingLeng) - 内核模块 Kbuild
#

# 源文件列表
bingleng-objs := \
    bingleng_main.o \
    utils.o \
    kallsyms.o \
    token_verify.o \
    gki_compat.o \
    arm64_hook.o \
    syscall_hook.o \
    priv_escalation.o \
    hide.o

# Android API 级别
ANDROID_API ?= 34

# 编译标志
ccflags-y := -Wall -Wextra
ccflags-y += -DCONFIG_ANDROID_API=$(ANDROID_API)

# 根据 Android API 定义兼容性宏
ccflags-y += -DCONFIG_ANDROID_10_COMPAT
ccflags-y += -DCONFIG_ANDROID_12_COMPAT
ccflags-y += -DCONFIG_ANDROID_16_COMPAT

# 声明模块
obj-$(CONFIG_BINGLENG) += bingleng.o

# 兼容性警告禁用
ccflags-y += -Wno-strict-prototypes
ccflags-y += -Wno-declaration-after-statement
ccflags-y += -Wno-unused-variable
ccflags-y += -Wno-unused-function
